generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaStatus {
  WATCHING
  COMPLETED
  PAUSED
  DROPPED
  PLANNING
  REWATCHING
  UPCOMING
}

enum MediaType {
  MOVIE
  TV_SEASON
}

model Entry {
  id            String      @id @default(cuid())
  tmdbId        Int         @unique
  parentTmdbId  Int?
  seasonNumber  Int?
  title         String
  type          MediaType
  status        MediaStatus @default(PLANNING)
  score         Float       @default(0)
  progress      Int         @default(0)
  totalEpisodes Int?

  startDate    DateTime?
  finishDate   DateTime?
  rewatchCount Int       @default(0)

  synopsis    String? @db.Text
  releaseDate String?
  endDate     String?
  format      String?
  rating      Float?
  popularity  Float?
  imagePath   String?
  bannerPath  String?
  customImage String?
  genres      String?
  studio      String?
  staff       Json?

  notes   String? @db.Text
  private Boolean @default(false)
  hidden  Boolean @default(false)

  isFavorite   Boolean @default(false)
  favoriteRank Int?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  // Relações corrigidas
  relationsFrom Relation[] @relation("SourceRelations")
  relationsTo   Relation[] @relation("TargetRelations")

  @@index([status])
  @@index([type])
  @@index([tmdbId])
  @@index([isFavorite])
}

model Relation {
  id String @id @default(cuid())

  sourceEntryId String
  targetEntryId String?

  relationType String

  title        String
  poster_path  String?
  kind         String
  year         String?
  seasonNumber Int?
  order        Int?

  targetTmdbId       Int
  targetParentTmdbId Int?
  targetSeasonNumber Int?
  targetType         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceEntry Entry  @relation("SourceRelations", fields: [sourceEntryId], references: [id], onDelete: Cascade)
  targetEntry Entry? @relation("TargetRelations", fields: [targetEntryId], references: [id], onDelete: SetNull)

  @@unique([sourceEntryId, targetTmdbId])
  @@index([sourceEntryId])
  @@index([targetEntryId])
}

model Profile {
  id          String   @id @default("main")
  username    String   @default("My Profile")
  bio         String?
  avatarUrl   String?
  bannerUrl   String?
  avatarColor String   @default("#3db4f2")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model UserGamification {
  id            String    @id @default(cuid())
  userId        String    @unique
  totalXP       Int       @default(0)
  currentLevel  Int       @default(1)
  xpToNextLevel Int       @default(1000)
  currentXP     Int       @default(0)
  badges        String[]  @default([])
  lastAwardedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([currentLevel])
  @@index([totalXP])
}

model GamificationActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  xpGained  Int
  metadata  Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
}

model StreakData {
  id              String    @id @default(cuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastActivityDay DateTime?
  updatedAt       DateTime  @updatedAt
}

model UserChallenge {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  periodKey   String
  category    String
  title       String
  description String
  type        String
  difficulty  String
  goal        Int
  current     Int       @default(0)
  rewardXP    Int
  rewardBadge String?
  metadata    Json      @default("{}")
  progressData Json     @default("{}")
  startsAt    DateTime
  expiresAt   DateTime
  completedAt DateTime?
  claimedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, challengeId, periodKey])
  @@index([userId, category, periodKey])
  @@index([userId, completedAt])
  @@index([expiresAt])
}

model ChallengeCompletion {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  periodKey   String
  category    String
  title       String
  xpAwarded   Int
  badge       String?
  completedAt DateTime @default(now())

  @@unique([userId, challengeId, periodKey])
  @@index([userId, completedAt])
  @@index([challengeId, periodKey])
}

model ActivityLog {
  id            String   @id @default(cuid())
  entryId       String
  title         String
  imagePath     String?
  type          String
  status        String
  progressStart Int?
  progressEnd   Int?
  score         Float
  slug          String
  createdAt     DateTime @default(now())
  lastUpdatedAt DateTime @updatedAt
}

model PersonalGoal {
  id        String    @id @default(cuid())
  userId    String    @default("main")
  title     String
  type      String
  target    Float
  current   Float     @default(0)
  unit      String    @default("")
  emoji     String    @default("🎯")
  deadline  DateTime?
  rewardXP  Int       @default(0)
  pinned    Boolean   @default(false)
  completed Boolean   @default(false)
  completedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([completed])
}