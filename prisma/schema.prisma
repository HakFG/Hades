generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaStatus {
  WATCHING
  COMPLETED
  PAUSED
  DROPPED
  PLANNING
  REWATCHING
  UPCOMING
}

enum MediaType {
  MOVIE
  TV_SEASON
}

model Entry {
  id            String      @id @default(cuid())
  tmdbId        Int         @unique
  parentTmdbId  Int?
  seasonNumber  Int?
  title         String
  type          MediaType
  status        MediaStatus @default(PLANNING)
  score         Float       @default(0)
  progress      Int         @default(0)
  totalEpisodes Int?

  startDate     DateTime?
  finishDate    DateTime?
  rewatchCount  Int         @default(0)

  synopsis      String?     @db.Text
  releaseDate   String?
  endDate       String?
  format        String?
  rating        Float?
  popularity    Float?
  imagePath     String?
  bannerPath    String?
  customImage   String?
  genres        String?
  studio        String?
  staff         Json?

  notes         String?     @db.Text
  private       Boolean     @default(false)
  hidden        Boolean     @default(false)

  isFavorite    Boolean     @default(false)
  favoriteRank  Int?

  updatedAt     DateTime    @updatedAt
  createdAt     DateTime    @default(now())

  // Relações corrigidas
  relationsFrom Relation[] @relation("SourceRelations")
  relationsTo   Relation[] @relation("TargetRelations")

  @@index([status])
  @@index([type])
  @@index([tmdbId])
  @@index([isFavorite])
}

model Relation {
  id            String   @id @default(cuid())

  sourceEntryId String
  targetEntryId String?

  relationType  String

  title         String
  poster_path   String?
  kind          String
  year          String?
  seasonNumber  Int?
  order         Int?

  targetTmdbId       Int
  targetParentTmdbId Int?
  targetSeasonNumber Int?
  targetType         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceEntry Entry  @relation("SourceRelations", fields: [sourceEntryId], references: [id], onDelete: Cascade)
  targetEntry Entry? @relation("TargetRelations", fields: [targetEntryId], references: [id], onDelete: SetNull)

  @@unique([sourceEntryId, targetTmdbId])
  @@index([sourceEntryId])
  @@index([targetEntryId])
}

model Profile {
  id          String   @id @default("main")
  username    String   @default("My Profile")
  bio         String?
  avatarUrl   String?
  bannerUrl   String?
  avatarColor String   @default("#3db4f2")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id             String   @id @default(cuid())
  entryId        String
  title          String
  imagePath      String?
  type           String
  status         String
  progressStart  Int?
  progressEnd    Int?
  score          Float
  slug           String
  createdAt      DateTime @default(now())
  lastUpdatedAt  DateTime @updatedAt
}